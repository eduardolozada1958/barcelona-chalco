# ============================================================
# ACADEMIA FC BARCELONA - BACKEND
# Variables de entorno - EXAMPLE
# Copiar este archivo como .env.development / .env.production
# NUNCA subir archivos .env reales al repositorio
# ============================================================

# ── Aplicación ──────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# ── Supabase ─────────────────────────────────────────────────
# Obtener desde: https://supabase.com/dashboard/project/<ID>/settings/api
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# ── JWT ──────────────────────────────────────────────────────
# Generar con: openssl rand -base64 64
JWT_SECRET=genera-un-secreto-seguro-minimo-64-caracteres-aqui
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=genera-otro-secreto-seguro-para-refresh-token-aqui
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# URL pública del frontend (Cloudflare Pages). Los QR de jugadores enlazan aquí + /credencial/:token
# Si se omite, se usa el primer origen de CORS_ORIGIN (si hay varios separados por coma).
# APP_PUBLIC_URL=https://barcelona-chalco.pages.dev

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=600

# ── Monitoreo (UptimeRobot, etc.) ─────────────────────────────
# GET público, sin auth y sin contar para rate limit:
#   https://<tu-servicio>.onrender.com/health
# En UptimeRobot: tipo HTTP(s), método GET, intervalo 5 min (o menos que el sleep de Render).

# ── bcrypt ───────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Logs ─────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=pretty

# ── Storage (Supabase Storage) ───────────────────────────────
STORAGE_BUCKET_PLAYERS=players-avatars
STORAGE_BUCKET_GALLERY=gallery
STORAGE_BUCKET_NOTICES=notices-covers
STORAGE_BUCKET_MATCH_LOGOS=match-logos
STORAGE_BUCKET_PLAYER_CURP=player-curp-documents
STORAGE_MAX_FILE_SIZE=5242880
STORAGE_MAX_CURP_PDF_BYTES=10485760

# ── Web Push (notificaciones de avisos urgentes / partidos / etc.) ──
# Generar par de claves: npx web-push generate-vapid-keys
# La pública también puede ir en el front como referencia; el panel la obtiene del API.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:contacto@fcbarcelonacupido.com

# ── SMTP Gmail (verificación de correo al registrarse como padre/tutor) ──
# Requisitos: cuenta Google con verificación en 2 pasos + «Contraseña de aplicación» (16 caracteres).
# Crear en: https://myaccount.google.com/apppasswords
# El remitente (SMTP_FROM) debe usar el MISMO correo que SMTP_USER (Gmail no permite otro dominio sin Workspace).
# En desarrollo, si SMTP_HOST no está definido, el enlace se imprime en los logs del backend.
#
# Producción en Render: plan Starter+ (Free bloquea salida SMTP). Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# (alternativa: PORT=587, SMTP_SECURE=false)
# SMTP_USER=elq.uayc@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM con nombre visible (válido) o solo el correo:
# SMTP_FROM="F.C. Barcelona Cupido <elq.uayc@gmail.com>"
# SMTP_FROM=elq.uayc@gmail.com
# EMAIL_VERIFICATION_HOURS=24
# APP_PUBLIC_URL=https://barcelona-chalco.pages.dev
