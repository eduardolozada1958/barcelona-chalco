# VITE_PUBLIC_APP_URL=https://barcelona-chalco.pages.dev
# VITE_APP_NAME=Academia Barcelona
#
# Mapas embebidos en fichas de partido (solo la URL del src del iframe de Google Maps, https://www.google.com/maps/embed?pb=...)
# VITE_VENUE_WALMART_MAP_EMBED_URL=
# VITE_VENUE_ATLAS_MAP_EMBED_URL=
# VITE_VENUE_CANCHAS100_MAP_EMBED_URL=
#
# Web Push: las claves VAPID van en el backend (Render). El front pide la pública a GET /push/public/vapid-key.
